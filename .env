# unicap auto-play VLM driver — copy to `.env` and fill in for `--driver vlm`.
#
# All three values are required. `VLM_BASE_URL` points at any OpenAI-compatible
# /v1/chat/completions endpoint that accepts image_url content blocks.
#
# Pick one of the cookbooks below, or point at your own provider / local server.

# ---- 阿里云百炼 Qwen-VL（推荐 — 国内最便宜的 vision API） ----
VLM_API_KEY=sk-a629ec18cc1347829c5d16450c8821d7
VLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
VLM_MODEL=qwen-vl-plus
# 备选模型: qwen3-vl-flash (更便宜，2026 新版) / qwen-vl-max (更强但贵)

# ---- Moonshot Kimi ----
# VLM_API_KEY=sk-...
# VLM_BASE_URL=https://api.moonshot.ai/v1
# VLM_MODEL=kimi-k2.6
# 备选: moonshot-v1-128k-vision-preview / kimi-k2.6-thinking

# ---- OpenAI ----
# VLM_API_KEY=sk-...
# VLM_BASE_URL=https://api.openai.com/v1
# VLM_MODEL=gpt-4o-mini
# 备选: gpt-4o (更强但贵)

# ---- 本地 Ollama / vLLM / LM Studio ----
# VLM_API_KEY=ollama          # Ollama 不校验，任意非空字符串
# VLM_BASE_URL=http://localhost:11434/v1
# VLM_MODEL=qwen3-vl:4b       # 按显卡 VRAM 选，对照表见下
#
# VRAM vs 模型大小对照（Ollama 默认 Q4_K_M 量化 + 4K context + vision encoder）:
#
#   VRAM    推荐模型                 单帧推理(参考)   典型卡 / 备注
#   ------  -----------------------  --------------  ------------------------------------
#   4 GB    qwen3-vl:2b              ~300 ms         RTX 2060 6GB / 集显勉强；质量一般
#   6-8 GB  qwen3-vl:4b              ~500 ms         RTX 2060 / 3060 / 4060；auto-play 下限
#   12 GB   qwen3-vl:8b              ~800 ms         RTX 3060 12GB / 4070 / 5070；推荐档位
#   16 GB   qwen3-vl:8b (Q8) / :12b  ~1.0-1.5 s      RTX 4080 / 5070 Ti
#   24 GB   qwen3-vl:30b (Q4_K_M)    ~3-5 s          RTX 3090 / 4090；auto-play 跟不上 1 Hz
#   32 GB+  qwen3-vl:30b (Q8) / 72b  ~5-10 s         RTX 5090 / A6000；同上，太慢
#
# auto-play 默认 1 Hz 决策率 —— 单帧推理 >1.5 s 会跟不上节奏（watchdog 会频繁触发）。
# 4090 装 30B 也只够 0.2-0.3 Hz，要本地跑大模型建议把 decision_period_s 调到 3-5 s。
#
# 本地 vs 云端（30 min FF7R 参考）:
#   云端 qwen-vl-plus：~$0.37 / 30min，延迟 ~500 ms 稳定，无显存压力
#   本地 qwen3-vl:8b（5070）：电费 ~$0.05 / 30min，延迟 ~800 ms，但要先下 5GB 模型
#   本地 qwen3-vl:30b（5070）：装不下，跑不动
#
# 没大显卡 / 不想折腾本地推理 → 直接用云端 Qwen-VL-Plus。
