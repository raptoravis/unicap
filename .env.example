# unicap auto-play VLM driver — copy to `.env` and fill in for `--driver vlm`.
#
# All three values are required. `VLM_BASE_URL` points at any OpenAI-compatible
# /v1/chat/completions endpoint that accepts image_url content blocks.
#
# Pick one of the cookbooks below, or point at your own provider / local server.

# ---- 阿里云百炼 Qwen-VL（推荐 — 国内最便宜的 vision API） ----
VLM_API_KEY=sk-...
VLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
VLM_MODEL=qwen-vl-plus
# 备选模型: qwen3-vl-flash (更便宜，2026 新版) / qwen-vl-max (更强但贵)

# ---- Moonshot Kimi ----
# VLM_API_KEY=sk-...
# VLM_BASE_URL=https://api.moonshot.ai/v1
# VLM_MODEL=kimi-k2.6
# 备选: moonshot-v1-128k-vision-preview / kimi-k2.6-thinking

# ---- OpenAI ----
# VLM_API_KEY=sk-...
# VLM_BASE_URL=https://api.openai.com/v1
# VLM_MODEL=gpt-4o-mini
# 备选: gpt-4o (更强但贵)

# ---- 本地 Ollama / vLLM / LM Studio ----
# VLM_API_KEY=ollama          # Ollama 不校验，任意非空字符串
# VLM_BASE_URL=http://localhost:11434/v1
# VLM_MODEL=qwen2-vl
